# Local ASR Service configuration
#
# Quick Docker start on the GPU machine:
#   1. Copy this file to .env
#        Windows: copy .env.example .env
#        Linux:   cp .env.example .env
#   2. Pick LOCAL_ASR_DEFAULT_MODEL below.
#   3. Pick NVIDIA_VISIBLE_DEVICES below.
#   4. Start:
#        Windows: scripts\run_docker_gpu.cmd
#        Linux:   docker compose -f docker-compose.gpu.yml up --build -d


# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

# 127.0.0.1 = service is reachable only on this machine.
# 0.0.0.0   = service is reachable from LAN. Use firewall rules and API key.
LOCAL_ASR_HOST=127.0.0.1

# External HTTP/WebSocket port.
LOCAL_ASR_PORT=8765

LOCAL_ASR_LOG_LEVEL=info

# Empty = auth disabled.
# Set a value for LAN mode, for example:
# LOCAL_ASR_API_KEY=change-me-long-random-token
LOCAL_ASR_API_KEY=


# ---------------------------------------------------------------------------
# Model selection
# ---------------------------------------------------------------------------

# Write the model profile id here.
#
# Available profiles from config/models.example.yaml:
#   mock                         - fake transcript, fastest API/UI smoke test.
#   fw-tiny-cpu                  - tiny real model on CPU, low quality.
#   fw-small-int8                - fast CUDA baseline.
#   fw-medium-int8               - recommended first real GPU model for GTX 1080 Ti.
#   fw-large-v3-turbo-int8       - best quality candidate for GTX 1080 Ti; benchmark latency.
#   fw-large-v3-turbo-int8-lowmem - lower-memory Docker test for GTX 1080 Ti.
#   fw-medium-int8-fp16          - newer GPUs with efficient FP16/Tensor Core support.
#   fw-large-v3-turbo-int8-fp16  - newer GPUs with efficient FP16/Tensor Core support.
#
# Recommended:
#   First start:        LOCAL_ASR_DEFAULT_MODEL=mock
#   GTX 1080 Ti Docker: LOCAL_ASR_DEFAULT_MODEL=fw-medium-int8
#   GTX 1080 Ti lowmem: LOCAL_ASR_DEFAULT_MODEL=fw-large-v3-turbo-int8-lowmem
#   GTX 1080 Ti best:   LOCAL_ASR_DEFAULT_MODEL=fw-large-v3-turbo-int8
#   RTX/newer live:     LOCAL_ASR_DEFAULT_MODEL=fw-medium-int8-fp16
LOCAL_ASR_DEFAULT_MODEL=mock

# Usually keep this unchanged.
LOCAL_ASR_MODELS_CONFIG=config/models.example.yaml


# ---------------------------------------------------------------------------
# GPU selection for Docker / NVIDIA runtime
# ---------------------------------------------------------------------------

# See GPUs on the target machine:
#   nvidia-smi
#
# See stable GPU UUIDs:
#   nvidia-smi --query-gpu=index,uuid,name --format=csv
#
# Choose which host GPU(s) Docker exposes to the container.
# You can use:
#   NVIDIA_VISIBLE_DEVICES=0
#   NVIDIA_VISIBLE_DEVICES=1
#   NVIDIA_VISIBLE_DEVICES=0,1
#   NVIDIA_VISIBLE_DEVICES=GPU-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Recommended simple mode for a multi-GPU host:
#   NVIDIA_VISIBLE_DEVICES=1
#   LOCAL_ASR_CUDA_DEVICE_INDEX=0
#
# Why index 0? If Docker exposes only host GPU 1, then inside the container
# that single visible GPU becomes CUDA device 0.
NVIDIA_VISIBLE_DEVICES=0

NVIDIA_DRIVER_CAPABILITIES=compute,utility

# CUDA device index visible inside the container/process.
# Leave empty/commented for profile default. Set 0 for the usual Docker case.
LOCAL_ASR_CUDA_DEVICE_INDEX=0


# ---------------------------------------------------------------------------
# Privacy and debug
# ---------------------------------------------------------------------------

# Keep these false by default. Do not save raw audio or transcripts unless you
# explicitly need debug artifacts.
LOCAL_ASR_SAVE_AUDIO=false
LOCAL_ASR_SAVE_TRANSCRIPTS=false
LOCAL_ASR_DEBUG_TRANSCRIPTS=false


# ---------------------------------------------------------------------------
# Streaming defaults
# ---------------------------------------------------------------------------

LOCAL_ASR_SAMPLE_RATE=16000
LOCAL_ASR_CHUNK_SECONDS=5
LOCAL_ASR_OVERLAP_SECONDS=1
